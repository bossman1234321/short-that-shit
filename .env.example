# SEC EDGAR requires a User-Agent header identifying the requester.
# Format: "Your Name your@email.com" — see https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT="Stock Screener research@example.com"

# Optional Polygon.io API key for fallback fundamentals when EDGAR rate-limits.
# Get a free key at https://polygon.io
POLYGON_API_KEY=

# Cache directory for fundamentals responses (default: .cache/edgar)
CACHE_DIR=.cache/edgar

# Telegram notifications. Set both to enable; leave blank to no-op.
#   1. Message @BotFather on Telegram → /newbot → save the token below.
#   2. Message your new bot once (anything) so it has your chat in scope.
#   3. curl https://api.telegram.org/bot<TOKEN>/getUpdates → copy the
#      "chat":{"id":...} value into TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Production URL used in notification links (default Vercel deployment).
SITE_URL=https://short-that-shit.vercel.app
